<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports"
              xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
              xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports
              http://jasperreports.sourceforge.net/xsd/jasperreport.xsd"
              name="iva_report"
              pageWidth="595" pageHeight="842"
              columnWidth="535" leftMargin="30" rightMargin="30"
              topMargin="20" bottomMargin="20"
              uuid="c3d4e5f6-a7b8-9012-cdef-345678901234">

  <parameter name="COMPANY_NAME"  class="java.lang.String"/>
  <parameter name="COMPANY_NIF"   class="java.lang.String"/>
  <parameter name="REPORT_TITLE"  class="java.lang.String"/>
  <parameter name="DATE_FROM"     class="java.lang.String"/>
  <parameter name="DATE_TO"       class="java.lang.String"/>
  <parameter name="TOTAL_BASE"    class="java.lang.String"/>
  <parameter name="TOTAL_IVA"     class="java.lang.String"/>
  <parameter name="GENERATED_AT"  class="java.lang.String"/>

  <field name="taxRate"    class="java.lang.String"/>
  <field name="baseAmount" class="java.lang.String"/>
  <field name="ivaAmount"  class="java.lang.String"/>

  <style name="base"   isDefault="true" fontName="DejaVu Sans" fontSize="9"/>
  <style name="header" fontName="DejaVu Sans" fontSize="9"  isBold="true" forecolor="#FFFFFF"/>
  <style name="title"  fontName="DejaVu Sans" fontSize="16" isBold="true" forecolor="#1a56db"/>
  <style name="mono"   fontName="DejaVu Sans Mono" fontSize="9"/>

  <title>
    <band height="90">
      <rectangle>
        <reportElement x="0" y="0" width="535" height="6" backcolor="#1a56db" forecolor="#1a56db"/>
        <graphicElement><pen lineWidth="0"/></graphicElement>
      </rectangle>
      <textField>
        <reportElement x="0" y="14" width="535" height="22" style="title"/>
        <textElement textAlignment="Center"/>
        <textFieldExpression><![CDATA[$P{REPORT_TITLE}]]></textFieldExpression>
      </textField>
      <textField>
        <reportElement x="0" y="40" width="535" height="12" forecolor="#374151"/>
        <textElement textAlignment="Center"><font size="10" isBold="true"/></textElement>
        <textFieldExpression><![CDATA[$P{COMPANY_NAME} + "   |   NIF: " + $P{COMPANY_NIF}]]></textFieldExpression>
      </textField>
      <textField>
        <reportElement x="0" y="56" width="535" height="12" forecolor="#6b7280"/>
        <textElement textAlignment="Center"/>
        <textFieldExpression><![CDATA["Período: " + $P{DATE_FROM} + " a " + $P{DATE_TO}]]></textFieldExpression>
      </textField>
      <line>
        <reportElement x="0" y="76" width="535" height="1" forecolor="#e5e7eb"/>
      </line>
    </band>
  </title>

  <columnHeader>
    <band height="22">
      <rectangle>
        <reportElement x="0" y="0" width="535" height="22" backcolor="#1a56db" forecolor="#1a56db"/>
        <graphicElement><pen lineWidth="0"/></graphicElement>
      </rectangle>
      <staticText>
        <reportElement x="10"  y="6" width="200" height="10" style="header"/>
        <text><![CDATA[TAXA DE IVA]]></text>
      </staticText>
      <staticText>
        <reportElement x="210" y="6" width="155" height="10" style="header"/>
        <textElement textAlignment="Right"/>
        <text><![CDATA[BASE TRIBUTÁVEL (AOA)]]></text>
      </staticText>
      <staticText>
        <reportElement x="365" y="6" width="160" height="10" style="header"/>
        <textElement textAlignment="Right"/>
        <text><![CDATA[IVA LIQUIDADO (AOA)]]></text>
      </staticText>
    </band>
  </columnHeader>

  <detail>
    <band height="20">
      <rectangle>
        <reportElement x="0" y="0" width="535" height="20" backcolor="#f9fafb" forecolor="#f9fafb">
          <printWhenExpression><![CDATA[$V{REPORT_COUNT} % 2 == 0]]></printWhenExpression>
        </reportElement>
        <graphicElement><pen lineWidth="0"/></graphicElement>
      </rectangle>
      <textField>
        <reportElement x="10"  y="5" width="200" height="10"/>
        <textElement><font isBold="true"/></textElement>
        <textFieldExpression><![CDATA[$F{taxRate}]]></textFieldExpression>
      </textField>
      <textField>
        <reportElement x="210" y="5" width="155" height="10" style="mono"/>
        <textElement textAlignment="Right"/>
        <textFieldExpression><![CDATA[$F{baseAmount}]]></textFieldExpression>
      </textField>
      <textField>
        <reportElement x="365" y="5" width="160" height="10" style="mono"/>
        <textElement textAlignment="Right"/>
        <textFieldExpression><![CDATA[$F{ivaAmount}]]></textFieldExpression>
      </textField>
      <line>
        <reportElement x="0" y="19" width="535" height="1" forecolor="#e5e7eb"/>
      </line>
    </band>
  </detail>

  <summary>
    <band height="80">
      <rectangle>
        <reportElement x="0" y="0" width="535" height="28" backcolor="#1e293b" forecolor="#1e293b"/>
        <graphicElement><pen lineWidth="0"/></graphicElement>
      </rectangle>
      <staticText>
        <reportElement x="10" y="8" width="200" height="12" forecolor="#FFFFFF"/>
        <textElement><font isBold="true" size="10"/></textElement>
        <text><![CDATA[TOTAL]]></text>
      </staticText>
      <textField>
        <reportElement x="210" y="8" width="155" height="12" forecolor="#58a6ff"/>
        <textElement textAlignment="Right"><font isBold="true" size="10"/></textElement>
        <textFieldExpression><![CDATA[$P{TOTAL_BASE}]]></textFieldExpression>
      </textField>
      <textField>
        <reportElement x="365" y="8" width="160" height="12" forecolor="#f87171"/>
        <textElement textAlignment="Right"><font isBold="true" size="10"/></textElement>
        <textFieldExpression><![CDATA[$P{TOTAL_IVA}]]></textFieldExpression>
      </textField>
      <textField>
        <reportElement x="0" y="42" width="535" height="10" forecolor="#9ca3af"/>
        <textElement textAlignment="Center"/>
        <textFieldExpression><![CDATA["Declaração gerada automaticamente em " + $P{GENERATED_AT} + " | Documento não substitui declaração oficial AGT"]]></textFieldExpression>
      </textField>
    </band>
  </summary>

</jasperReport>
