      <staticText><reportElement x="4"   y="54" width="180" height="10"/><text><![CDATA[Subsídio de Transporte]]></text></staticText>
      <textField><reportElement x="184" y="54" width="76" height="10" style="mono"/><textElement textAlignment="Right"/><textFieldExpression><![CDATA[$P{TRANSPORT_ALLOWANCE}]]></textFieldExpression></textField>
      <line><reportElement x="0" y="64" width="260" height="1" forecolor="#e5e7eb"/></line>

      <staticText><reportElement x="4"   y="66" width="180" height="10"/><text><![CDATA[Subsídio de Habitação]]></text></staticText>
      <textField><reportElement x="184" y="66" width="76" height="10" style="mono"/><textElement textAlignment="Right"/><textFieldExpression><![CDATA[$P{HOUSING_ALLOWANCE}]]></textFieldExpression></textField>
      <line><reportElement x="0" y="76" width="260" height="1" forecolor="#e5e7eb"/></line>

      <staticText><reportElement x="4"   y="78" width="180" height="10"/><text><![CDATA[Abono de Família]]></text></staticText>
      <textField><reportElement x="184" y="78" width="76" height="10" style="mono"/><textElement textAlignment="Right"/><textFieldExpression><![CDATA[$P{FAMILY_ALLOWANCE}]]></textFieldExpression></textField>
      <line><reportElement x="0" y="88" width="260" height="1" forecolor="#e5e7eb"/></line>

      <staticText><reportElement x="4"   y="90" width="180" height="10"/><text><![CDATA[Bónus de Produção]]></text></staticText>
      <textField><reportElement x="184" y="90" width="76" height="10" style="mono"/><textElement textAlignment="Right"/><textFieldExpression><![CDATA[$P{PRODUCTION_BONUS}]]></textFieldExpression></textField>
      <line><reportElement x="0" y="100" width="260" height="1" forecolor="#e5e7eb"/></line>

      <staticText><reportElement x="4"   y="102" width="180" height="10"/><text><![CDATA[Horas Extra]]></text></staticText>
      <textField><reportElement x="184" y="102" width="76" height="10" style="mono"/><textElement textAlignment="Right"/><textFieldExpression><![CDATA[$P{OVERTIME_PAY}]]></textFieldExpression></textField>
      <line><reportElement x="0" y="112" width="260" height="1" forecolor="#e5e7eb"/></line>

      <staticText><reportElement x="4"   y="114" width="180" height="10"/><text><![CDATA[Outros Abonos]]></text></staticText>
      <textField><reportElement x="184" y="114" width="76" height="10" style="mono"/><textElement textAlignment="Right"/><textFieldExpression><![CDATA[$P{OTHER_ALLOWANCES}]]></textFieldExpression></textField>
      <line><reportElement x="0" y="124" width="260" height="1" forecolor="#e5e7eb"/></line>

      <!-- Total Abonos -->
      <rectangle><reportElement x="0" y="126" width="260" height="16" backcolor="#f0f9ff" forecolor="#f0f9ff"/><graphicElement><pen lineWidth="0"/></graphicElement></rectangle>
      <staticText><reportElement x="4" y="131" width="180" height="10" style="bold"/><text><![CDATA[TOTAL ABONOS (Salário Bruto)]]></text></staticText>
      <textField><reportElement x="184" y="131" width="76" height="10" style="monoRight"/><textElement textAlignment="Right"><font isBold="true"/></textElement><textFieldExpression><![CDATA[$P{GROSS_SALARY}]]></textFieldExpression></textField>

      <!-- Descontos -->
      <staticText><reportElement x="279" y="30" width="160" height="10"/><textFieldExpression/><text><![CDATA[INSS Empregado (3%)]]></text></staticText>
      <textField><reportElement x="459" y="30" width="76" height="10" style="mono" forecolor="#dc2626"/><textElement textAlignment="Right"/><textFieldExpression><![CDATA[$P{INSS_EMPLOYEE}]]></textFieldExpression></textField>
      <line><reportElement x="275" y="40" width="260" height="1" forecolor="#e5e7eb"/></line>

      <staticText><reportElement x="279" y="42" width="160" height="10"/><text><![CDATA[IRT (]]></text></staticText>
      <textField><reportElement x="291" y="42" width="80" height="10"/><textFieldExpression><![CDATA["IRT (" + $P{IRT_RATE} + " efectivo)"]]></textFieldExpression></textField>
      <textField><reportElement x="459" y="42" width="76" height="10" style="mono" forecolor="#dc2626"/><textElement textAlignment="Right"/><textFieldExpression><![CDATA[$P{IRT_AMOUNT}]]></textFieldExpression></textField>
      <line><reportElement x="275" y="52" width="260" height="1" forecolor="#e5e7eb"/></line>

      <staticText><reportElement x="279" y="54" width="160" height="10"/><text><![CDATA[Adiantamentos]]></text></staticText>
      <textField><reportElement x="459" y="54" width="76" height="10" style="mono" forecolor="#dc2626"/><textElement textAlignment="Right"/><textFieldExpression><![CDATA[$P{ADVANCE_DED}]]></textFieldExpression></textField>
      <line><reportElement x="275" y="64" width="260" height="1" forecolor="#e5e7eb"/></line>

      <staticText><reportElement x="279" y="66" width="160" height="10"/><text><![CDATA[Empréstimos]]></text></staticText>
      <textField><reportElement x="459" y="66" width="76" height="10" style="mono" forecolor="#dc2626"/><textElement textAlignment="Right"/><textFieldExpression><![CDATA[$P{LOAN_DED}]]></textFieldExpression></textField>
      <line><reportElement x="275" y="76" width="260" height="1" forecolor="#e5e7eb"/></line>

      <staticText><reportElement x="279" y="78" width="160" height="10"/><text><![CDATA[Outros Descontos]]></text></staticText>
      <textField><reportElement x="459" y="78" width="76" height="10" style="mono" forecolor="#dc2626"/><textElement textAlignment="Right"/><textFieldExpression><![CDATA[$P{OTHER_DED}]]></textFieldExpression></textField>
      <line><reportElement x="275" y="88" width="260" height="1" forecolor="#e5e7eb"/></line>

      <!-- Total Descontos -->
      <rectangle><reportElement x="275" y="126" width="260" height="16" backcolor="#fff0f0" forecolor="#fff0f0"/><graphicElement><pen lineWidth="0"/></graphicElement></rectangle>
      <staticText><reportElement x="279" y="131" width="180" height="10" style="bold"/><text><![CDATA[TOTAL DESCONTOS]]></text></staticText>
      <textField><reportElement x="459" y="131" width="76" height="10" forecolor="#dc2626"/><textElement textAlignment="Right"><font isBold="true" fontName="DejaVu Sans Mono"/></textElement><textFieldExpression><![CDATA[$P{TOTAL_DEDUCTIONS}]]></textFieldExpression></textField>

      <!-- ══ Salário Líquido ══ -->
      <rectangle><reportElement x="0" y="154" width="535" height="36" backcolor="#1a56db" forecolor="#1a56db"/><graphicElement><pen lineWidth="0"/></graphicElement></rectangle>
      <staticText><reportElement x="10" y="162" width="200" height="20" style="netLbl"/><text><![CDATA[SALÁRIO LÍQUIDO A RECEBER:]]></text></staticText>
      <textField><reportElement x="210" y="160" width="315" height="24" style="netVal"/><textElement textAlignment="Right"/><textFieldExpression><![CDATA[$P{NET_SALARY}]]></textFieldExpression></textField>

      <!-- Valor por extenso -->
      <textField isStretchWithOverflow="true">
        <reportElement x="0" y="196" width="535" height="14" forecolor="#374151"/>
        <textElement><font size="8" isItalic="true"/></textElement>
        <textFieldExpression><![CDATA["Valor por extenso: " + $P{NET_WORDS}]]></textFieldExpression>
      </textField>

      <!-- ══ Dados bancários ══ -->
      <line><reportElement x="0" y="216" width="535" height="1" forecolor="#e5e7eb"/></line>
      <staticText><reportElement x="0" y="220" width="535" height="8" style="section"/><text><![CDATA[DADOS PARA PAGAMENTO]]></text></staticText>
      <textField><reportElement x="0" y="230" width="535" height="10"/><textFieldExpression><![CDATA["Banco: " + $P{EMP_BANK} + "  |  Conta: " + $P{EMP_ACCOUNT}]]></textFieldExpression></textField>

      <!-- ══ INSS Entidade Empregadora ══ -->
      <line><reportElement x="0" y="246" width="535" height="1" forecolor="#e5e7eb"/></line>
      <rectangle><reportElement x="0" y="250" width="535" height="24" backcolor="#f8fafc" forecolor="#f8fafc"/><graphicElement><pen lineWidth="0"/></graphicElement></rectangle>
      <staticText><reportElement x="6" y="254" width="350" height="8" style="section"/><text><![CDATA[ENCARGO INSS ENTIDADE EMPREGADORA (8%) — NÃO DEDUZIDO AO COLABORADOR]]></text></staticText>
      <textField><reportElement x="356" y="254" width="175" height="8" style="mono" forecolor="#6b7280"/><textElement textAlignment="Right"/><textFieldExpression><![CDATA[$P{INSS_EMPLOYER}]]></textFieldExpression></textField>

      <!-- ══ Rodapé ══ -->
      <line><reportElement x="0" y="282" width="535" height="1" forecolor="#e5e7eb"/></line>
      <rectangle><reportElement x="0" y="284" width="535" height="30" backcolor="#f3f4f6" forecolor="#f3f4f6"/><graphicElement><pen lineWidth="0"/></graphicElement></rectangle>
      <textField><reportElement x="0" y="292" width="535" height="10" forecolor="#9ca3af"/><textElement textAlignment="Center"><font size="7"/></textElement><textFieldExpression><![CDATA[$P{COMPANY_NAME} + " | NIF: " + $P{COMPANY_NIF} + " | Recibo gerado em: " + $P{GENERATED_AT}]]></textFieldExpression></textField>
      <staticText><reportElement x="0" y="304" width="535" height="8" forecolor="#9ca3af"/><textElement textAlignment="Center"><font size="7"/></textElement><text><![CDATA[Este documento tem valor legal apenas quando assinado pelas partes.]]></text></staticText>

      <!-- Assinaturas -->
      <line><reportElement x="30"  y="336" width="180" height="1" forecolor="#374151"/></line>
      <line><reportElement x="325" y="336" width="180" height="1" forecolor="#374151"/></line>
      <staticText><reportElement x="30"  y="340" width="180" height="8" forecolor="#374151"/><textElement textAlignment="Center"/><text><![CDATA[Assinatura do Colaborador]]></text></staticText>
      <staticText><reportElement x="325" y="340" width="180" height="8" forecolor="#374151"/><textElement textAlignment="Center"/><text><![CDATA[Assinatura da Entidade Empregadora]]></text></staticText>

