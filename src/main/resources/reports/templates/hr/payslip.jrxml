<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports"
              xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
              xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports
              http://jasperreports.sourceforge.net/xsd/jasperreport.xsd"
              name="payslip" pageWidth="595" pageHeight="842"
              columnWidth="535" leftMargin="30" rightMargin="30"
              topMargin="20" bottomMargin="20"
              uuid="e5f6a7b8-c9d0-1234-efab-567890123456">

  <!-- Parâmetros -->
  <parameter name="COMPANY_NAME"    class="java.lang.String"/>
  <parameter name="COMPANY_NIF"     class="java.lang.String"/>
  <parameter name="COMPANY_ADDRESS" class="java.lang.String"/>
  <parameter name="EMP_NUMBER"      class="java.lang.String"/>
  <parameter name="EMP_NAME"        class="java.lang.String"/>
  <parameter name="EMP_POSITION"    class="java.lang.String"/>
  <parameter name="EMP_DEPARTMENT"  class="java.lang.String"/>
  <parameter name="EMP_NIF"         class="java.lang.String"/>
  <parameter name="EMP_INSS"        class="java.lang.String"/>
  <parameter name="EMP_BANK"        class="java.lang.String"/>
  <parameter name="EMP_ACCOUNT"     class="java.lang.String"/>
  <parameter name="PERIOD"          class="java.lang.String"/>
  <parameter name="WORKING_DAYS"    class="java.lang.Integer"/>
  <parameter name="ATTENDED_DAYS"   class="java.lang.Integer"/>
  <parameter name="ABSENT_DAYS"     class="java.lang.Integer"/>
  <parameter name="BASE_SALARY"     class="java.lang.String"/>
  <parameter name="FOOD_ALLOWANCE"  class="java.lang.String"/>
  <parameter name="TRANSPORT_ALLOWANCE" class="java.lang.String"/>
  <parameter name="HOUSING_ALLOWANCE"   class="java.lang.String"/>
  <parameter name="FAMILY_ALLOWANCE"    class="java.lang.String"/>
  <parameter name="PRODUCTION_BONUS"    class="java.lang.String"/>
  <parameter name="OVERTIME_PAY"        class="java.lang.String"/>
  <parameter name="OTHER_ALLOWANCES"    class="java.lang.String"/>
  <parameter name="TOTAL_ALLOWANCES"    class="java.lang.String"/>
  <parameter name="GROSS_SALARY"    class="java.lang.String"/>
  <parameter name="INSS_EMPLOYEE"   class="java.lang.String"/>
  <parameter name="INSS_RATE"       class="java.lang.String"/>
  <parameter name="IRT_AMOUNT"      class="java.lang.String"/>
  <parameter name="IRT_RATE"        class="java.lang.String"/>
  <parameter name="ADVANCE_DED"     class="java.lang.String"/>
  <parameter name="LOAN_DED"        class="java.lang.String"/>
  <parameter name="OTHER_DED"       class="java.lang.String"/>
  <parameter name="TOTAL_DEDUCTIONS" class="java.lang.String"/>
  <parameter name="NET_SALARY"      class="java.lang.String"/>
  <parameter name="NET_WORDS"       class="java.lang.String"/>
  <parameter name="INSS_EMPLOYER"   class="java.lang.String"/>
  <parameter name="INSS_EMP_RATE"   class="java.lang.String"/>
  <parameter name="GENERATED_AT"    class="java.lang.String"/>
  <parameter name="STATUS"          class="java.lang.String"/>

  <field name="description" class="java.lang.String"/>

  <!-- Estilos -->
  <style name="base"      isDefault="true" fontName="DejaVu Sans" fontSize="8" forecolor="#1a1a2e"/>
  <style name="bold"      fontName="DejaVu Sans" fontSize="8"  isBold="true"/>
  <style name="title"     fontName="DejaVu Sans" fontSize="16" isBold="true" forecolor="#1a56db"/>
  <style name="section"   fontName="DejaVu Sans" fontSize="7"  isBold="true" forecolor="#6b7280" isUpperCase="true"/>
  <style name="mono"      fontName="DejaVu Sans Mono" fontSize="8" forecolor="#1a56db"/>
  <style name="monoRight" fontName="DejaVu Sans Mono" fontSize="8" forecolor="#1a56db"/>
  <style name="totalLbl"  fontName="DejaVu Sans" fontSize="9" isBold="true"/>
  <style name="totalVal"  fontName="DejaVu Sans Mono" fontSize="10" isBold="true" forecolor="#1a56db"/>
  <style name="netLbl"    fontName="DejaVu Sans" fontSize="11" isBold="true" forecolor="#FFFFFF"/>
  <style name="netVal"    fontName="DejaVu Sans Mono" fontSize="13" isBold="true" forecolor="#FFFFFF"/>
  <style name="thdr"      fontName="DejaVu Sans" fontSize="7"  isBold="true" forecolor="#FFFFFF"/>

  <title>
    <band height="130">
      <!-- Faixa topo -->
      <rectangle><reportElement x="0" y="0" width="535" height="6" backcolor="#1a56db" forecolor="#1a56db"/><graphicElement><pen lineWidth="0"/></graphicElement></rectangle>

      <!-- Título -->
      <staticText><reportElement x="0" y="12" width="535" height="24" style="title"/><textElement textAlignment="Center"/><text><![CDATA[RECIBO DE VENCIMENTO]]></text></staticText>

      <!-- Empresa (esq) -->
      <textField><reportElement x="0" y="40" width="280" height="12"/><textElement><font size="10" isBold="true"/></textElement><textFieldExpression><![CDATA[$P{COMPANY_NAME}]]></textFieldExpression></textField>
      <textField><reportElement x="0" y="54" width="280" height="10" forecolor="#6b7280"/><textFieldExpression><![CDATA["NIF: " + $P{COMPANY_NIF}]]></textFieldExpression></textField>
      <textField isStretchWithOverflow="true"><reportElement x="0" y="66" width="280" height="20" forecolor="#6b7280"/><textFieldExpression><![CDATA[$P{COMPANY_ADDRESS}]]></textFieldExpression></textField>

      <!-- Período (dir) -->
      <rectangle><reportElement x="330" y="40" width="205" height="50" backcolor="#f0f7ff" forecolor="#f0f7ff"/><graphicElement><pen lineWidth="0"/></graphicElement></rectangle>
      <staticText><reportElement x="336" y="46" width="193" height="8" style="section"/><textElement textAlignment="Center"/><text><![CDATA[PERÍODO DE PROCESSAMENTO]]></text></staticText>
      <textField><reportElement x="336" y="58" width="193" height="18" forecolor="#1a56db"/><textElement textAlignment="Center"><font size="14" isBold="true"/></textElement><textFieldExpression><![CDATA[$P{PERIOD}]]></textFieldExpression></textField>
      <textField><reportElement x="336" y="78" width="193" height="10" forecolor="#6b7280"/><textElement textAlignment="Center"/><textFieldExpression><![CDATA["Estado: " + $P{STATUS}]]></textFieldExpression></textField>

      <line><reportElement x="0" y="96" width="535" height="1" forecolor="#e5e7eb"/></line>

      <!-- Dados colaborador -->
      <staticText><reportElement x="0"  y="102" width="80" height="8" style="section"/><text><![CDATA[COLABORADOR]]></text></staticText>
      <textField><reportElement x="80" y="102" width="250" height="8"/><textElement><font isBold="true"/></textElement><textFieldExpression><![CDATA[$P{EMP_NAME}]]></textFieldExpression></textField>
      <staticText><reportElement x="330" y="102" width="50" height="8" style="section"/><text><![CDATA[Nº:]]></text></staticText>
      <textField><reportElement x="380" y="102" width="155" height="8" style="mono"/><textFieldExpression><![CDATA[$P{EMP_NUMBER}]]></textFieldExpression></textField>

      <staticText><reportElement x="0"  y="114" width="80" height="8" style="section"/><text><![CDATA[CARGO]]></text></staticText>
      <textField><reportElement x="80" y="114" width="180" height="8"/><textFieldExpression><![CDATA[$P{EMP_POSITION}]]></textFieldExpression></textField>
      <staticText><reportElement x="260" y="114" width="70" height="8" style="section"/><text><![CDATA[DEPARTAMENTO]]></text></staticText>
      <textField><reportElement x="330" y="114" width="205" height="8"/><textFieldExpression><![CDATA[$P{EMP_DEPARTMENT}]]></textFieldExpression></textField>

      <staticText><reportElement x="0"  y="126" width="80" height="8" style="section"/><text><![CDATA[NIF]]></text></staticText>
      <textField><reportElement x="80" y="126" width="80" height="8" style="mono"/><textFieldExpression><![CDATA[$P{EMP_NIF}]]></textFieldExpression></textField>
      <staticText><reportElement x="160" y="126" width="60" height="8" style="section"/><text><![CDATA[INSS Nº]]></text></staticText>
      <textField><reportElement x="220" y="126" width="100" height="8" style="mono"/><textFieldExpression><![CDATA[$P{EMP_INSS}]]></textFieldExpression></textField>
      <staticText><reportElement x="330" y="126" width="50" height="8" style="section"/><text><![CDATA[DIAS]]></text></staticText>
      <textField><reportElement x="380" y="126" width="155" height="8"/><textFieldExpression><![CDATA["Trab: " + $P{ATTENDED_DAYS} + "  Falta: " + $P{ABSENT_DAYS} + "  Total: " + $P{WORKING_DAYS}]]></textFieldExpression></textField>
    </band>
  </title>

  <!-- Linhas de detalhe (1 linha vazia — tabela abaixo no summary) -->
  <detail><band height="0"/></detail>

  <summary>
    <band height="440" splitType="Stretch">

      <!-- ══ Tabela Abonos / Descontos ══ -->

      <!-- Cabeçalhos -->
      <rectangle><reportElement x="0" y="8" width="260" height="16" backcolor="#1a56db" forecolor="#1a56db"/><graphicElement><pen lineWidth="0"/></graphicElement></rectangle>
      <staticText><reportElement x="4" y="13" width="180" height="8" style="thdr"/><text><![CDATA[ABONOS / VENCIMENTOS]]></text></staticText>
      <staticText><reportElement x="184" y="13" width="76" height="8" style="thdr"/><textElement textAlignment="Right"/><text><![CDATA[VALOR (AOA)]]></text></staticText>

      <rectangle><reportElement x="275" y="8" width="260" height="16" backcolor="#dc2626" forecolor="#dc2626"/><graphicElement><pen lineWidth="0"/></graphicElement></rectangle>
      <staticText><reportElement x="279" y="13" width="180" height="8" style="thdr"/><text><![CDATA[DESCONTOS]]></text></staticText>
      <staticText><reportElement x="459" y="13" width="76" height="8" style="thdr"/><textElement textAlignment="Right"/><text><![CDATA[VALOR (AOA)]]></text></staticText>

      <!-- Abonos -->
      <!-- Salário base -->
      <staticText><reportElement x="4"   y="30" width="180" height="10"/><text><![CDATA[Salário Base]]></text></staticText>
      <textField><reportElement x="184" y="30" width="76" height="10" style="mono"/><textElement textAlignment="Right"/><textFieldExpression><![CDATA[$P{BASE_SALARY}]]></textFieldExpression></textField>
      <line><reportElement x="0" y="40" width="260" height="1" forecolor="#e5e7eb"/></line>

      <staticText><reportElement x="4"   y="42" width="180" height="10"/><text><![CDATA[Subsídio de Alimentação]]></text></staticText>
      <textField><reportElement x="184" y="42" width="76" height="10" style="mono"/><textElement textAlignment="Right"/><textFieldExpression><![CDATA[$P{FOOD_ALLOWANCE}]]></textFieldExpression></textField>
