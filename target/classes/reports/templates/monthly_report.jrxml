<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports"
              xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
              xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports
              http://jasperreports.sourceforge.net/xsd/jasperreport.xsd"
              name="monthly_report"
              pageWidth="595" pageHeight="842"
              columnWidth="535" leftMargin="30" rightMargin="30"
              topMargin="20" bottomMargin="20"
              uuid="d4e5f6a7-b8c9-0123-defa-456789012345">

  <parameter name="COMPANY_NAME"   class="java.lang.String"/>
  <parameter name="COMPANY_NIF"    class="java.lang.String"/>
  <parameter name="REPORT_TITLE"   class="java.lang.String"/>
  <parameter name="YEAR"           class="java.lang.String"/>
  <parameter name="TOTAL_REVENUE"  class="java.lang.String"/>
  <parameter name="GENERATED_AT"   class="java.lang.String"/>

  <field name="month"            class="java.lang.Integer"/>
  <field name="monthName"        class="java.lang.String"/>
  <field name="invoiceCount"     class="java.lang.Integer"/>
  <field name="revenueFormatted" class="java.lang.String"/>
  <field name="taxesFormatted"   class="java.lang.String"/>

  <style name="base"   isDefault="true" fontName="DejaVu Sans" fontSize="9"/>
  <style name="header" fontName="DejaVu Sans" fontSize="9" isBold="true" forecolor="#FFFFFF"/>
  <style name="title"  fontName="DejaVu Sans" fontSize="16" isBold="true" forecolor="#1a56db"/>
  <style name="mono"   fontName="DejaVu Sans Mono" fontSize="9" forecolor="#1a56db"/>

  <title>
    <band height="80">
      <rectangle>
        <reportElement x="0" y="0" width="535" height="6" backcolor="#1a56db" forecolor="#1a56db"/>
        <graphicElement><pen lineWidth="0"/></graphicElement>
      </rectangle>
      <textField>
        <reportElement x="0" y="14" width="535" height="22" style="title"/>
        <textElement textAlignment="Center"/>
        <textFieldExpression><![CDATA[$P{REPORT_TITLE}]]></textFieldExpression>
      </textField>
      <textField>
        <reportElement x="0" y="40" width="535" height="12" forecolor="#374151"/>
        <textElement textAlignment="Center"><font size="10" isBold="true"/></textElement>
        <textFieldExpression><![CDATA[$P{COMPANY_NAME} + "   |   NIF: " + $P{COMPANY_NIF}]]></textFieldExpression>
      </textField>
    </band>
  </title>

  <columnHeader>
    <band height="20">
      <rectangle>
        <reportElement x="0" y="0" width="535" height="20" backcolor="#1a56db" forecolor="#1a56db"/>
        <graphicElement><pen lineWidth="0"/></graphicElement>
      </rectangle>
      <staticText><reportElement x="10"  y="5" width="120" height="10" style="header"/><text><![CDATA[MÊS]]></text></staticText>
      <staticText><reportElement x="130" y="5" width="80"  height="10" style="header"/><textElement textAlignment="Center"/><text><![CDATA[Nº FACTURAS]]></text></staticText>
      <staticText><reportElement x="210" y="5" width="160" height="10" style="header"/><textElement textAlignment="Right"/><text><![CDATA[FACTURAÇÃO (AOA)]]></text></staticText>
      <staticText><reportElement x="370" y="5" width="155" height="10" style="header"/><textElement textAlignment="Right"/><text><![CDATA[IVA (AOA)]]></text></staticText>
    </band>
  </columnHeader>

  <detail>
    <band height="20">
      <rectangle>
        <reportElement x="0" y="0" width="535" height="20" backcolor="#f9fafb" forecolor="#f9fafb">
          <printWhenExpression><![CDATA[$V{REPORT_COUNT} % 2 == 0]]></printWhenExpression>
        </reportElement>
        <graphicElement><pen lineWidth="0"/></graphicElement>
      </rectangle>
      <textField>
        <reportElement x="10"  y="5" width="118" height="10"/>
        <textElement><font isBold="true"/></textElement>
        <textFieldExpression><![CDATA[$F{monthName}]]></textFieldExpression>
      </textField>
      <textField>
        <reportElement x="130" y="5" width="78"  height="10" forecolor="#6b7280"/>
        <textElement textAlignment="Center"/>
        <textFieldExpression><![CDATA[$F{invoiceCount}]]></textFieldExpression>
      </textField>
      <textField>
        <reportElement x="210" y="5" width="158" height="10" style="mono"/>
        <textElement textAlignment="Right"/>
        <textFieldExpression><![CDATA[$F{revenueFormatted}]]></textFieldExpression>
      </textField>
      <textField>
        <reportElement x="370" y="5" width="155" height="10" forecolor="#6b7280"/>
        <textElement textAlignment="Right"/>
        <textFieldExpression><![CDATA[$F{taxesFormatted}]]></textFieldExpression>
      </textField>
      <line><reportElement x="0" y="19" width="535" height="1" forecolor="#e5e7eb"/></line>
    </band>
  </detail>

  <summary>
    <band height="50">
      <rectangle>
        <reportElement x="0" y="0" width="535" height="26" backcolor="#1e293b" forecolor="#1e293b"/>
        <graphicElement><pen lineWidth="0"/></graphicElement>
      </rectangle>
      <staticText>
        <reportElement x="10" y="8" width="200" height="10" forecolor="#FFFFFF"/>
        <textElement><font isBold="true"/></textElement>
        <text><![CDATA[TOTAL ANUAL]]></text>
      </staticText>
      <textField>
        <reportElement x="210" y="8" width="315" height="10" forecolor="#58a6ff"/>
        <textElement textAlignment="Right"><font isBold="true" size="11"/></textElement>
        <textFieldExpression><![CDATA[$P{TOTAL_REVENUE}]]></textFieldExpression>
      </textField>
      <textField>
        <reportElement x="0" y="34" width="535" height="10" forecolor="#9ca3af"/>
        <textElement textAlignment="Center"/>
        <textFieldExpression><![CDATA["Gerado em: " + $P{GENERATED_AT}]]></textFieldExpression>
      </textField>
    </band>
  </summary>

</jasperReport>
